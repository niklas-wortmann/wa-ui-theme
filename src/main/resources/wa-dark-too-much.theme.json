    "Button.default.endBackground": "wa.ochre",
    "Button.default.foreground": "wa.bg0",

    "ProgressBar.trackColor": "wa.bg2",
    "ProgressBar.progressColor": "wa.teal",

    "ScrollBar.thumb": "wa.rose",
    "ScrollBar.track": "wa.bg1",

    "List.background": "wa.bg1",
    "List.foreground": "wa.fg1",
    "List.selectionBackground": "wa.teal",
    "List.selectionForeground": "wa.bg0",

    "Tree.background": "wa.bg1",
    "Tree.foreground": "wa.fg1",
    "Tree.selectionBackground": "wa.teal",
    "Tree.selectionForeground": "wa.bg0",

    "Table.background": "wa.bg1",
