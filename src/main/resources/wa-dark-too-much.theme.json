{
  "name": "WA Dark (Vibrant)",
  "dark": true,
  "parentTheme": "Islands Dark",
  "author": "Jan-Niklas Wortmann",
  "editorScheme": "Darcula",

  "colors": {
    "wa.bg0": "#1A1417",
    "wa.bg1": "#24171D",
    "wa.bg2": "#2E1F29",
    "wa.bg3": "#3A2A35",

    "wa.fg0": "#FFF1DE",
    "wa.fg1": "#F1D3C7",
    "wa.fg2": "#D0B3AA",

    "wa.border": "#6E4D55",
    "wa.borderSoft": "#4B343B",

    "wa.teal": "#2FA39A",
    "wa.mint": "#B9E9DF",
    "wa.brass": "#D7B35B",
    "wa.ochre": "#E4C06B",
    "wa.terracotta": "#D47A5E",
    "wa.rose": "#D28AA2",
    "wa.sky": "#87C7DA",

    "wa.selectBg": "#2FA39A",
    "wa.selectFg": "#1A1417",

    "wa.danger": "#D06057",
    "wa.warn": "#D7B35B",
    "wa.ok": "#62B07A",

    "wa.link": "#87C7DA",
    "wa.caret": "#FFF1DE"
