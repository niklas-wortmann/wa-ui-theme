    "Popup.Header.activeBackground": "wa.rose",
    "Popup.Header.inactiveBackground": "wa.bg2",

    "SearchEverywhere.SearchField.background": "wa.bg2",
    "SearchEverywhere.SearchField.foreground": "wa.fg0",

    "TextField.background": "wa.bg2",
    "TextField.foreground": "wa.fg0",
    "TextField.caretForeground": "wa.caret",
    "TextField.selectionBackground": "wa.mint",
    "TextField.selectionForeground": "wa.bg0",

    "TextArea.background": "wa.bg2",
    "TextArea.foreground": "wa.fg0",
    "TextArea.caretForeground": "wa.caret",
    "TextArea.selectionBackground": "wa.mint",
    "TextArea.selectionForeground": "wa.bg0",

    "ComboBox.background": "wa.bg2",
    "ComboBox.foreground": "wa.fg0",

